MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_DB_NAME=crisisweave_db
PORT=4000
DEDUP_RADIUS_KM=1
DEDUP_WINDOW_MINUTES=60

# LLM reasoning providers. Gemini is primary, Groq is fallback, local logic is final fallback.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Seed demo admin/staff accounts. Replace before sharing or deploying.
SEED_ADMIN_EMAIL=admin@crisisweave.local
SEED_ADMIN_PASSWORD=change-me-admin-password
SEED_STAFF_EMAIL=staff@crisisweave.local
SEED_STAFF_PASSWORD=change-me-staff-password
